---
import BaseLayout from '../layouts/BaseLayout.astro';
import { generatePersonLD } from '../utils/seo';

const personLD = generatePersonLD({
  name: 'Khalid Ait Bellahs',
  url: 'https://khalid.science/cv',
  image: 'https://khalid.science/images/author.jpg',
  jobTitle: 'Biomédico em formação & Engenheiro de Software Full-Stack',
  sameAs: [
    'https://orcid.org/0009-0004-5917-3376',
    'https://scholar.google.com/citations?user=lT4DgnkAAAAJ',
    'https://github.com/kaitbellahs',
    'https://lattes.cnpq.br/4727731542228802',
  ],
});
---

<BaseLayout
  title="Currículo"
  description="Currículo acadêmico e profissional de Khalid Ait Bellahs — biomédico em formação, desenvolvedor full-stack e pesquisador em biogerontologia."
  image="/images/author.jpg"
  type="profile"
  jsonLD={personLD}
>
  <section class="container container--narrow section">
    <h1>Currículo</h1>

    <!-- ── Formação Acadêmica ── -->
    <div class="cv-section">
      <h2>Formação Acadêmica</h2>
      <div class="cv-item">
        <div class="cv-item__header">
          <h3>Biomedicina (Bacharelado)</h3>
          <span class="cv-item__status">Em curso — 2º Semestre (2026)</span>
        </div>
        <p>Universidade Positivo — Campus Ecoville, Curitiba/PR</p>
      </div>
      <div class="cv-item">
        <div class="cv-item__header">
          <h3>Análise e Desenvolvimento de Sistemas (Tecnólogo)</h3>
          <span class="cv-item__status cv-item__status--done">Concluído (2025)</span>
        </div>
        <p>ETEP Faculdades</p>
      </div>
    </div>

    <!-- ── Experiência Profissional ── -->
    <div class="cv-section">
      <h2>Experiência Profissional</h2>

      <div class="cv-item">
        <div class="cv-item__header">
          <h3>Fundador & Engenheiro de Software Full-Stack</h3>
          <span class="cv-item__date">2024 – Atual</span>
        </div>
        <p><strong>Trusom</strong> — Empresa de desenvolvimento de software · Curitiba/PR</p>
        <ul>
          <li>
            <strong>TruArm</strong> — Plataforma SaaS de gestão clínica e empresarial (CRM + ERP).
            Arquitetura multi-tenant com RBAC granular, módulos de agendamento, formulários dinâmicos,
            gestão inteligente de estoque com integração ERP, relatórios PDF comparativos e
            comunicação em tempo real via WebSockets.
          </li>
          <li>
            <strong>Social Gateway</strong> — Plataforma de comunicação multicanal para atendimento
            ao cliente, integrando múltiplos canais em interface unificada.
          </li>
        </ul>
        <p class="cv-item__tech">
          <strong>Stack:</strong> TypeScript · NestJS · React · Next.js · MariaDB · TypeORM ·
          PostgreSQL · MongoDB · Socket.IO · Docker · Cloudflare Workers
        </p>
      </div>
    </div>

    <!-- ── Áreas de Pesquisa ── -->
    <div class="cv-section">
      <h2>Áreas de Pesquisa</h2>
      <ul>
        <li>Biogerontologia translacional e mecanismos moleculares do envelhecimento</li>
        <li>Senescência celular, telômeros, SASP e estratégias senolíticas</li>
        <li>IA aplicada à descoberta farmacológica e reprogramação epigenética</li>
        <li>Geopolítica e ética da longevidade radical</li>
        <li>Bioinformática e multi-ômica preditiva</li>
        <li>Interseção entre tecnologia (IA, blockchain, DeSci) e ciências biomédicas</li>
      </ul>
    </div>

    <!-- ── Produção Científica ── -->
    <div class="cv-section">
      <h2>Produção Científica</h2>

      <h3 class="cv-subsection-title">Artigos Acadêmicos (2026)</h3>
      <ol>
        <li>
          <strong>Mecanismos Moleculares do Envelhecimento Humano: Dos Hallmarks à Senescência Negligenciável</strong>
          — Revisão narrativa · <a href="/blog/mecanismos-moleculares-envelhecimento" aria-label="Ler artigo: Mecanismos Moleculares do Envelhecimento Humano">Leia</a>
        </li>
        <li>
          <strong>Inteligência Artificial na Biogerontologia Translacional: Descoberta Farmacológica e Reprogramação Epigenética</strong>
          — Revisão narrativa com perspectiva · <a href="/blog/ia-biogerontologia-translacional" aria-label="Ler artigo: IA na Biogerontologia Translacional">Leia</a>
        </li>
        <li>
          <strong>Geopolítica e Impacto Societal da Longevidade Radical</strong>
          — Artigo de perspectiva / ensaio acadêmico · <a href="/blog/geopolitica-longevidade-radical" aria-label="Ler artigo: Geopolítica e Longevidade Radical">Leia</a>
        </li>
      </ol>

      <h3 class="cv-subsection-title">Divulgação Científica (2026)</h3>
      <ol>
        <li>
          <strong>Reprogramação epigenética em humanos: Life Biosciences prepara primeiro ensaio clínico para 2026</strong>
          · <a href="/blog/reprogramacao-epigenetica-humanos-2026" aria-label="Ler artigo: Reprogramação epigenética em humanos">Leia</a>
        </li>
        <li>
          <strong>70+ ensaios clínicos de senolíticos: o campo que cresceu 60% em 3 anos</strong>
          · <a href="/blog/ensaios-clinicos-senoliticos-2025" aria-label="Ler artigo: Ensaios clínicos de senolíticos">Leia</a>
        </li>
        <li>
          <strong>GLP-1 e longevidade: como agonistas de incretinas surpreenderam a gerontologia</strong>
          · <a href="/blog/glp1-longevidade-incretinas" aria-label="Ler artigo: GLP-1 e longevidade">Leia</a>
        </li>
        <li>
          <strong>Urolitina A e saúde mitocondrial: o que o estudo iScience 2025 revelou</strong>
          · <a href="/blog/urolitina-a-saude-mitocondrial" aria-label="Ler artigo: Urolitina A e saúde mitocondrial">Leia</a>
        </li>
        <li>
          <strong>O pipeline de 2026: Retro, Rubedo, Juvena, Cyclarity e a corrida por dados de Fase I</strong>
          · <a href="/blog/pipeline-longevidade-2026" aria-label="Ler artigo: Pipeline de longevidade 2026">Leia</a>
        </li>
      </ol>
    </div>

    <!-- ── Notas de Pesquisa ── -->
    <div class="cv-section">
      <h2>Notas de Pesquisa</h2>
      <ul>
        <li>
          <strong>Hipótese: CD38 como alvo central na cascata SASP→NAD+→senescência</strong>
          — Proposta de que a inibição farmacológica de CD38 pode ser mais eficaz que a
          suplementação direta de NAD+ para quebrar o ciclo de retroalimentação entre
          senescência celular e depleção metabólica.
        </li>
      </ul>
    </div>

    <!-- ── Competências Técnicas ── -->
    <div class="cv-section">
      <h2>Competências Técnicas</h2>
      <div class="skills-grid">
        <div class="skill-group">
          <h4>Back-end</h4>
          <p>Node.js, NestJS, TypeORM, REST APIs, WebSockets (Socket.IO), MariaDB, PostgreSQL, MongoDB</p>
        </div>
        <div class="skill-group">
          <h4>Front-end</h4>
          <p>React, Next.js, Angular, TypeScript, HTML/CSS, Astro</p>
        </div>
        <div class="skill-group">
          <h4>DevOps & Infra</h4>
          <p>Docker, Cloudflare Workers/Pages, GitHub Actions, Git</p>
        </div>
        <div class="skill-group">
          <h4>Ciências Biomédicas</h4>
          <p>Biologia molecular, Bioquímica, Bioinformática, Análise de dados, Revisão de literatura científica</p>
        </div>
        <div class="skill-group">
          <h4>Idiomas</h4>
          <p>Português (nativo), Inglês (avançado), Francês (básico)</p>
        </div>
      </div>
    </div>

    <!-- ── Perfis ── -->
    <div class="cv-section">
      <h2>Perfis</h2>
      <div class="profiles">
        <a href="https://orcid.org/0009-0004-5917-3376" target="_blank" rel="noopener noreferrer">ORCID</a>
        <a href="https://scholar.google.com/citations?user=lT4DgnkAAAAJ&hl=pt-BR&authuser=1" target="_blank" rel="noopener noreferrer">Google Scholar</a>
        <a href="https://lattes.cnpq.br/4727731542228802" target="_blank" rel="noopener noreferrer">Lattes</a>
        <a href="https://github.com/kaitbellahs" target="_blank" rel="noopener noreferrer">GitHub</a>
      </div>
    </div>

    <!-- <p style="margin-top:var(--space-8);">
      <a href="/files/cv-khalid.pdf" download>📄 Download CV (PDF)</a>
    </p> -->
  </section>
</BaseLayout>

<style>
  .cv-section {
    margin-bottom: var(--space-10);
  }

  .cv-item {
    padding: var(--space-4) 0;
    border-bottom: 1px solid var(--color-border-subtle);
  }

  .cv-item:last-child { border-bottom: none; }

  .cv-item__header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    flex-wrap: wrap;
    gap: var(--space-2);
  }

  .cv-item__header h3 {
    margin: 0;
    font-size: var(--font-size-lg);
  }

  .cv-item__status {
    font-size: var(--font-size-xs);
    padding: 0.2em 0.6em;
    border-radius: 9999px;
    background: var(--color-accent-bg);
    color: var(--color-accent);
    font-weight: 600;
  }

  .cv-item__status--done {
    background: var(--color-accent-bg);
    color: var(--color-accent);
  }

  .cv-item__date {
    font-size: var(--font-size-sm);
    color: var(--color-text-muted);
  }

  .cv-item__tech {
    font-size: var(--font-size-sm);
    color: var(--color-text-secondary);
    margin-top: var(--space-2);
  }

  .cv-subsection-title {
    font-size: var(--font-size-base);
    color: var(--color-accent);
    margin-top: var(--space-4);
    margin-bottom: var(--space-2);
    font-weight: 600;
  }

  .skills-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: var(--space-4);
  }

  .skill-group h4 {
    margin: 0 0 var(--space-1);
    font-size: var(--font-size-sm);
    color: var(--color-accent);
  }

  .skill-group p {
    font-size: var(--font-size-sm);
    color: var(--color-text-secondary);
  }

  .profiles {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
  }

  .profiles a {
    padding: var(--space-2) var(--space-4);
    border: 1px solid var(--color-border);
    border-radius: var(--border-radius);
    font-size: var(--font-size-sm);
    transition: all var(--transition-normal);
  }

  .profiles a:hover {
    border-color: var(--color-accent);
    background: var(--color-accent-bg);
    text-decoration: none;
  }
</style>
