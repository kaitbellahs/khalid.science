---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allPubs = (await getCollection('publications'))
  .sort((a, b) => b.data.year - a.data.year);

const typeLabels: Record<string, string> = {
  review: 'Revisão',
  article: 'Artigo',
  preprint: 'Preprint',
  thesis: 'Tese/Dissertação',
};
---

<BaseLayout
  title="Publicações"
  description="Publicações acadêmicas de Khalid Ait Bellahs — artigos de revisão em biogerontologia e IA."
>
  <section class="container container--narrow section">
    <h1>Publicações acadêmicas</h1>
    <p class="page-desc">Artigos de revisão e perspectiva em biogerontologia, IA e longevidade.</p>

    <div class="pub-list">
      {allPubs.map((pub) => (
        <div class="pub-item" id={`pub-${pub.id}`}>
          <div class="pub-type">
            <span class="tag">{typeLabels[pub.data.type] || pub.data.type}</span>
            <span class="pub-year">{pub.data.year}</span>
          </div>
          <h2 class="pub-title">{pub.data.title}</h2>
          <p class="pub-authors">{pub.data.authors}</p>
          {pub.data.journal && <p class="pub-journal"><em>{pub.data.journal}</em></p>}
          {pub.data.abstract && <p class="pub-abstract">{pub.data.abstract}</p>}
          <div class="pub-links">
            {pub.data.doi && (
              <a href={`https://doi.org/${pub.data.doi}`} target="_blank" rel="noopener noreferrer">
                DOI: {pub.data.doi}
              </a>
            )}
            {pub.data.url && (
              <a href={pub.data.url} target="_blank" rel="noopener noreferrer">
                Texto completo ↗
              </a>
            )}
          </div>
        </div>
      ))}
    </div>

    {allPubs.length === 0 && (
      <p class="empty-state">Publicações em preparação.</p>
    )}
  </section>
</BaseLayout>

<style>
  .page-desc {
    color: var(--color-text-secondary);
    margin-bottom: var(--space-8);
  }

  .pub-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-8);
  }

  .pub-item {
    padding-bottom: var(--space-8);
    border-bottom: 1px solid var(--color-border);
  }

  .pub-item:last-child { border-bottom: none; }

  .pub-type {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    margin-bottom: var(--space-2);
  }

  .pub-year {
    font-size: var(--font-size-sm);
    color: var(--color-text-muted);
  }

  .pub-title {
    font-size: var(--font-size-xl);
    margin-top: 0;
    margin-bottom: var(--space-2);
  }

  .pub-authors {
    font-size: var(--font-size-sm);
    color: var(--color-text-secondary);
    margin-bottom: var(--space-1);
  }

  .pub-journal {
    font-size: var(--font-size-sm);
    color: var(--color-text-muted);
    margin-bottom: var(--space-2);
  }

  .pub-abstract {
    font-size: var(--font-size-sm);
    color: var(--color-text-secondary);
    line-height: 1.6;
    margin-bottom: var(--space-3);
  }

  .pub-links {
    display: flex;
    gap: var(--space-4);
    font-size: var(--font-size-sm);
  }

  .empty-state {
    color: var(--color-text-muted);
    font-style: italic;
    text-align: center;
    padding: var(--space-12) 0;
  }
</style>
