---
interface Props {
  period: string;
  degree: string;
  institution: string;
  status: 'em_curso' | 'concluido' | 'trancado';
  description?: string;
}

const { period, degree, institution, status, description } = Astro.props;

const statusConfig = {
  em_curso: { label: 'Em curso', className: 'status--active' },
  concluido: { label: 'Concluído', className: 'status--done' },
  trancado: { label: 'Trancado', className: 'status--paused' },
} as const;

const { label, className } = statusConfig[status];
---

<div class="education-card">
  <div class="education-card__header">
    <span class="education-card__period">{period}</span>
    <span class={`education-card__status ${className}`}>{label}</span>
  </div>
  <h3 class="education-card__degree">{degree}</h3>
  <p class="education-card__institution">{institution}</p>
  {description && <p class="education-card__desc">{description}</p>}
</div>

<style>
  .education-card {
    padding: var(--space-5) var(--space-6);
    border: 1px solid var(--color-border);
    border-radius: var(--border-radius);
    background: var(--color-surface);
    transition: border-color var(--transition-normal), box-shadow var(--transition-normal);
  }

  .education-card:hover {
    border-color: var(--color-accent);
    box-shadow: 0 4px 20px color-mix(in srgb, var(--color-accent) 8%, transparent);
  }

  .education-card__header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: var(--space-2);
  }

  .education-card__period {
    font-size: var(--font-size-xs);
    font-weight: 600;
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .education-card__status {
    font-size: var(--font-size-xs);
    font-weight: 600;
    padding: 2px var(--space-2);
    border-radius: 9999px;
  }

  .status--active {
    background: var(--color-accent-bg);
    color: var(--color-accent);
  }

  .status--done {
    --_status-color: #15803d;
    background: color-mix(in srgb, var(--_status-color) 10%, transparent);
    color: var(--_status-color);
  }

  :root.dark .status--done {
    --_status-color: #4ade80;
  }

  .status--paused {
    --_status-color: #b45309;
    background: color-mix(in srgb, var(--_status-color) 10%, transparent);
    color: var(--_status-color);
  }

  :root.dark .status--paused {
    --_status-color: #fbbf24;
  }

  .education-card__degree {
    font-size: var(--font-size-lg);
    font-weight: 700;
    margin-bottom: var(--space-1);
  }

  .education-card__institution {
    font-size: var(--font-size-sm);
    color: var(--color-accent);
    font-weight: 500;
    margin: 0;
  }

  .education-card__desc {
    font-size: var(--font-size-sm);
    color: var(--color-text-secondary);
    margin-top: var(--space-2);
    margin-bottom: 0;
  }
</style>
