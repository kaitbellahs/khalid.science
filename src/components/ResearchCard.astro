---
interface Props {
  icon: string;
  title: string;
  description: string;
  href?: string;
}

const { icon, title, description, href } = Astro.props;
const Tag = href ? 'a' : 'div';
---

<Tag class="research-card" href={href}>
  <span class="research-card__icon">{icon}</span>
  <div class="research-card__content">
    <h3 class="research-card__title">{title}</h3>
    <p class="research-card__desc">{description}</p>
  </div>
</Tag>

<style>
  .research-card {
    display: flex;
    gap: var(--space-4);
    padding: var(--space-5) var(--space-6);
    border: 1px solid var(--color-border);
    border-radius: var(--border-radius);
    background: var(--color-surface);
    transition: border-color var(--transition-normal), box-shadow var(--transition-normal), transform var(--transition-normal);
    text-decoration: none;
    color: inherit;
  }

  .research-card:hover {
    border-color: var(--color-accent);
    box-shadow: 0 4px 20px color-mix(in srgb, var(--color-accent) 8%, transparent);
    transform: translateY(-2px);
    text-decoration: none;
  }

  .research-card__icon {
    font-size: var(--font-size-2xl);
    flex-shrink: 0;
    width: 48px;
    height: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--color-accent-bg);
    border-radius: var(--border-radius);
  }

  .research-card__title {
    font-size: var(--font-size-lg);
    font-weight: 600;
    margin-bottom: var(--space-1);
  }

  .research-card__desc {
    font-size: var(--font-size-sm);
    color: var(--color-text-secondary);
    line-height: var(--line-height-normal);
    margin: 0;
  }
</style>
