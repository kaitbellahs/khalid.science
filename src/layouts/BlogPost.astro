---
import BaseLayout from './BaseLayout.astro';
import TableOfContents from '../components/TableOfContents.astro';
import CiteThis from '../components/CiteThis.astro';
import GiscusComments from '../components/GiscusComments.astro';
import { generateScholarlyArticleLD } from '../utils/seo';

interface Props {
  title: string;
  description: string;
  date: Date;
  updated?: Date;
  tags: string[];
  doi?: string;
  headings: { depth: number; slug: string; text: string }[];
}

const { title, description, date, updated, tags, doi, headings } = Astro.props;

const dateFormatted = date.toLocaleDateString('pt-BR', {
  day: '2-digit', month: 'long', year: 'numeric'
});

const updatedFormatted = updated?.toLocaleDateString('pt-BR', {
  day: '2-digit', month: 'long', year: 'numeric'
});

const jsonLD = generateScholarlyArticleLD({
  title,
  description,
  datePublished: date.toISOString(),
  dateModified: updated?.toISOString(),
  url: Astro.url.href,
  doi,
});
---

<BaseLayout title={title} description={description} type="article" jsonLD={jsonLD}>
  <article class="container container--narrow section">
    <header class="post-header">
      <h1>{title}</h1>
      <div class="post-meta">
        <time datetime={date.toISOString()}>📅 {dateFormatted}</time>
        {updated && (
          <span class="post-meta__updated">
            · Atualizado em <time datetime={updated.toISOString()}>{updatedFormatted}</time>
          </span>
        )}
      </div>
      <div class="post-tags">
        {tags.map((tag) => (
          <a href={`/blog?tag=${tag}`} class="tag">{tag}</a>
        ))}
      </div>
    </header>

    <TableOfContents headings={headings} />

    <div class="prose">
      <slot />
    </div>

    <CiteThis
      title={title}
      date={date}
      url={Astro.url.href}
      doi={doi}
    />

    <GiscusComments />
  </article>
</BaseLayout>

<style>
  .post-header {
    margin-bottom: var(--space-8);
  }

  .post-meta {
    font-size: var(--font-size-sm);
    color: var(--color-text-secondary);
    margin-bottom: var(--space-3);
  }

  .post-meta__updated {
    color: var(--color-text-muted);
  }

  .post-tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
  }
</style>
